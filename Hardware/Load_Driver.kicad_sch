	)
	(text "Design Notes"
		(exclude_from_sim no)
		(at 17.018 131.826 0)
		(effects
			(font
				(size 3.302 3.302)
				(thickness 0.6604)
				(bold yes)
			)
			(justify left top)
		)
		(uuid "2a1e7f96-fbad-4d58-afec-2c2f677ffec2")
	)
	(text "- The load driver ICs are the recommended TPL7407LA's.\n- The drivers themselves have only 7 channels, from which we need 2 and have to double up on 3 more.\n- Thus, to split the current evenly (put equal load on both ICs), I've set one HighDrive (single channel\n   running a relay coil) per IC, and an additional doubled up LowDrive (1.6A direct draw) per IC. Then,\n   for the last LowDrive, I've split it up between the two ICs.\n- This shouldn't cause problems, since both ICs share a common ground, and V_GS will be positive for both."
		(exclude_from_sim no)
		(at 17.78 138.938 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left top)
		)
		(uuid "ab7f1046-4df7-4ae8-87d0-3cec26eea2d2")
	)
	(text "Global/Hierarchical Labels"
		(exclude_from_sim no)
		(at 162.052 132.588 0)
		(effects
			(font
				(size 3.302 3.302)
				(thickness 0.6604)
				(bold yes)
			)
			(justify left top)
		)
		(uuid "e5fd4c81-9662-4c7d-b4b5-f43f61615e87")
	)
	(text "DIN 72552 Standard\n\n- 30: Common\n- 85: Coil Ground\n- 86: Coil Positive\n- 87: Normally Open Output\n- 87A: Normally Closed Output"
		(exclude_from_sim no)
		(at 44.45 66.675 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left top)
		)
		(uuid "ee9647b0-be73-4b14-92ba-fa4a1488bdb6")
	)
